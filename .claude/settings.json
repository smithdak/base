{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "args": [
              "__hook",
              "pre-tool",
              "--target",
              "claude",
              "--default-branch",
              "main"
            ],
            "command": "base",
            "statusMessage": "Checking base gates",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "^(?:Bash)$"
      },
      {
        "hooks": [
          {
            "args": [
              "__hook",
              "pre-tool",
              "--target",
              "claude",
              "--default-branch",
              "main"
            ],
            "command": "base",
            "statusMessage": "Checking base gates",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "^(?:Edit|Write|NotebookEdit)$"
      },
      {
        "hooks": [
          {
            "args": [
              "__hook",
              "pre-tool",
              "--target",
              "claude",
              "--default-branch",
              "main"
            ],
            "command": "base",
            "statusMessage": "Checking base gates",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "^(?:mcp__github__.*)$"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "args": [
              "__hook",
              "policy",
              "session-context",
              "--target",
              "claude"
            ],
            "command": "base",
            "statusMessage": "Running base policy session-context",
            "timeout": 12,
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Bash(git push * main*)",
      "Bash(git push * HEAD:main*)"
    ]
  }
}

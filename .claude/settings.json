{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "args": [
              "__hook",
              "claude-pre-tool",
              "--default-branch",
              "main"
            ],
            "command": "base",
            "if": "Bash(git push *)",
            "statusMessage": "Checking base standing denials",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ]
  },
  "permissions": {
    "deny": [
      "Bash(git push * main*)",
      "Bash(git push * HEAD:main*)"
    ]
  }
}
